{
  "id": "shared/personal/v1",
  "kind": "shared-profile",
  "extends": [],
  "help": {
    "defaultFormat": "json",
    "supportedFormats": ["json", "text"]
  },
  "rules": {
    "enforced": {
      "folderCase": "camelCase",
      "functionStyle": "arrow",
      "handlerNaming": {
        "internal": "^handle[A-Z].*$",
        "propCallback": "^on[A-Z].*$"
      },
      "arrayNaming": {
        "pluralRequired": true,
        "forbiddenSuffixes": ["List", "Array"]
      },
      "typeNaming": {
        "interface": "PascalCase",
        "typeAlias": "PascalCase"
      },
      "typePlacement": {
        "localSingleUse": "same-file-or-local-folder",
        "globalSharedRoots": ["types/common", "types/{domain}"]
      }
    }
  },
  "commands": {
    "type": {
      "description": "Render a shared type snippet",
      "inputMode": "json",
      "execution": {
        "kind": "snippet",
        "language": "ts"
      },
      "defaults": {
        "kind": "interface"
      },
      "templateFiles": {
        "interface": "templates/type.interface.ts",
        "type": "templates/type.alias.ts"
      },
      "examples": [
        "tcp type --json '{\"name\":\"TableColumn\",\"kind\":\"interface\"}'",
        "tcf type --json '{\"name\":\"ProductSummary\",\"kind\":\"type\"}'"
      ]
    },
    "props": {
      "description": "Render props members only snippet",
      "inputMode": "json",
      "execution": {
        "kind": "snippet",
        "language": "ts"
      },
      "examples": [
        "tcp props --json '{\"members\":[{\"kind\":\"value\",\"name\":\"title\",\"type\":\"string\",\"required\":true}]}'"
      ]
    },
    "function": {
      "description": "Render a shared function snippet",
      "inputMode": "json",
      "execution": {
        "kind": "snippet",
        "language": "ts"
      },
      "examples": [
        "tcf function --json '{\"kind\":\"internalHandler\",\"name\":\"onClick\"}'"
      ]
    }
  }
}

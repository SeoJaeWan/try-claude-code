          "packagePathDot",
          "basePackagePath",
          "recordFields"
        ]
      },
      "examples": [
        "backend responseDto --json '{\"name\":\"ProductResponse\",\"path\":\"product\",\"basePackage\":\"com.example.app\"}'"
      ]
    },
    "entity": {
      "description": "Generate a Spring entity",
      "summary": {
        "whenToUse": [
          "When you need a JPA entity shell"
        ],
        "relatedCommands": [
          {
            "id": "module",
            "reason": "Generate the skeleton for the same feature"
          },
          {
            "id": "requestDto",
            "reason": "Align request DTO fields with domain fields"
          },
          {
            "id": "responseDto",
            "reason": "Align response DTO fields with domain fields"
          },
          {
            "id": "batch",
            "reason": "Run multiple file generation tasks in one request"
          }
        ],
        "flowRefs": [
          "create-spring-feature",
          "bulk-backend-scaffold"
        ]
      },
      "guide": {
        "목적": "Spring entity 파일을 생성한다.",
        "입력규칙": [
          "name과 path는 필수다.",
          "fields 배열로 엔티티 필드를 전달할 수 있다."
        ],
        "이름규칙": [

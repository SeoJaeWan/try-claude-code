      },
      "fieldResolvers": [
        {
          "field": "basePackage",
          "source": "detector",
          "detector": "springBasePackage",
          "code": "ROOT_PACKAGE_NOT_FOUND",
          "message": "Spring root package could not be detected. Provide basePackage in the JSON spec.",
          "details": {
            "command": "entity"
          }
        }
      ],
      "generator": {

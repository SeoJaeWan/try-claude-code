{
  "id": "backend/personal/v1",
  "kind": "backend-profile",
  "alias": "tcb",
  "extends": [],
  "help": {
    "defaultFormat": "json",
    "supportedFormats": ["json", "text"]
  },
  "metadata": {
    "sourceBackedDefaults": [
      "Avoid the default package and keep the application class at the root package.",
      "Use @Valid for request validation.",
      "Use @ControllerAdvice and ResponseEntityExceptionHandler for REST errors."
    ],
    "inferredChoices": [
      "Use package-by-feature.",
      "Split feature packages into controller, service, dto, entity, repository."
    ]
  },
  "commands": {
    "module": {
      "description": "Generate a Spring feature module skeleton",
      "inputMode": "json",
      "execution": {
        "kind": "file"
      },
      "inputSchema": {
        "required": ["name", "path"]
      },
      "generator": {
        "kind": "multiFile",
        "requiresBasePackage": true
      },
      "normalizationRules": [
        {
          "kind": "case",
          "field": "name",
          "style": "pascal",
          "reason": "classes use PascalCase"
        },
        {
          "kind": "path",
          "field": "path"
        }
      ],
      "validatorRules": [
        {
          "kind": "nameCase",
          "field": "name",
          "style": "pascal",
          "message": "Class name must use PascalCase"
        },
        {
          "kind": "pathSegmentCase",
          "field": "path",
          "style": "lower",
          "code": "INVALID_PACKAGE_SEGMENT",
          "message": "Backend package segments must use lower-case"
        },
        {
          "kind": "springBasePackage",
          "field": "basePackage"
        }
      ],
      "render": {
        "templateFiles": {
          "controller": "templates/module.controller.java",
          "service": "templates/module.service.java",
          "repository": "templates/module.repository.java",
          "globalExceptionHandler": "templates/module.global-exception-handler.java"
        },
        "fileEntries": [
          {
            "templateKey": "controller",
            "filePattern": "src/main/java/{basePackagePath}/{path}/controller/{name}Controller.java"
          },
          {
            "templateKey": "service",
            "filePattern": "src/main/java/{basePackagePath}/{path}/service/{name}Service.java"
          },
          {
            "templateKey": "repository",
            "filePattern": "src/main/java/{basePackagePath}/{path}/repository/{name}Repository.java"
          },
          {
            "templateKey": "globalExceptionHandler",
            "filePattern": "src/main/java/{basePackagePath}/global/exception/GlobalExceptionHandler.java"
          }
        ],
        "contextTokens": ["className", "featurePackage", "featurePath", "basePackage", "packagePathDot", "basePackagePath"]
      },
      "examples": [
        "tcb module --json '{\"name\":\"Product\",\"path\":\"product\",\"basePackage\":\"com.example.app\"}'"
      ]
    },
    "requestDto": {
      "description": "Generate a Spring request DTO",
      "inputMode": "json",
      "execution": {
        "kind": "file"
      },
      "inputSchema": {
        "required": ["name", "path"],
        "arrays": ["fields"]
      },
      "defaults": {
        "fields": []
      },
      "generator": {
        "kind": "singleFile",
        "requiresBasePackage": true
      },
      "normalizationRules": [
        {
          "kind": "case",
          "field": "name",
          "style": "pascal",
          "reason": "classes use PascalCase"
        },
        {
          "kind": "path",
          "field": "path"
        },
        {
          "kind": "listItemNames",
          "field": "fields",
          "style": "camel",
          "reason": "field names use camelCase"
        }
      ],
      "validatorRules": [
        {
          "kind": "nameCase",
          "field": "name",
          "style": "pascal",
          "message": "Class name must use PascalCase"
        },
        {
          "kind": "pathSegmentCase",
          "field": "path",
          "style": "lower",
          "code": "INVALID_PACKAGE_SEGMENT",
          "message": "Backend package segments must use lower-case"
        },
        {
          "kind": "springBasePackage",
          "field": "basePackage"
        }
      ],
      "render": {
        "templateFile": "templates/request-dto.java",
        "output": {
          "filePattern": "src/main/java/{basePackagePath}/{path}/dto/{name}.java"
        },
        "contextTokens": ["className", "basePackage", "packagePathDot", "basePackagePath", "recordFields"]
      },
      "examples": [
        "tcb requestDto --json '{\"name\":\"CreateProductRequest\",\"path\":\"product\",\"basePackage\":\"com.example.app\",\"fields\":[{\"name\":\"name\",\"type\":\"String\",\"validations\":[\"NotBlank\"]}]}'"
      ]
    },
    "responseDto": {
      "description": "Generate a Spring response DTO",
      "inputMode": "json",
      "execution": {
        "kind": "file"
      },
      "inputSchema": {
        "required": ["name", "path"],
        "arrays": ["fields"]
      },
      "defaults": {
        "fields": []
      },
      "generator": {
        "kind": "singleFile",
        "requiresBasePackage": true
      },
      "normalizationRules": [
        {
          "kind": "case",
          "field": "name",
          "style": "pascal",
          "reason": "classes use PascalCase"
        },
        {
          "kind": "path",
          "field": "path"
        },
        {
          "kind": "listItemNames",
          "field": "fields",
          "style": "camel",
          "reason": "field names use camelCase"
        }
      ],
      "validatorRules": [
        {
          "kind": "nameCase",
          "field": "name",
          "style": "pascal",
          "message": "Class name must use PascalCase"
        },
        {
          "kind": "pathSegmentCase",
          "field": "path",
          "style": "lower",
          "code": "INVALID_PACKAGE_SEGMENT",
          "message": "Backend package segments must use lower-case"
        },
        {
          "kind": "springBasePackage",
          "field": "basePackage"
        }
      ],
      "render": {
        "templateFile": "templates/response-dto.java",
        "output": {
          "filePattern": "src/main/java/{basePackagePath}/{path}/dto/{name}.java"
        },
        "contextTokens": ["className", "basePackage", "packagePathDot", "basePackagePath", "recordFields"]
      },
      "examples": [
        "tcb responseDto --json '{\"name\":\"ProductResponse\",\"path\":\"product\",\"basePackage\":\"com.example.app\"}'"
      ]
    },
    "entity": {
      "description": "Generate a Spring entity",
      "inputMode": "json",
      "execution": {
        "kind": "file"
      },
      "inputSchema": {
        "required": ["name", "path"],
        "arrays": ["fields"]
      },
      "defaults": {
        "fields": []
      },
      "generator": {
        "kind": "singleFile",
        "requiresBasePackage": true
      },
      "normalizationRules": [
        {
          "kind": "case",
          "field": "name",
          "style": "pascal",
          "reason": "classes use PascalCase"
        },
        {
          "kind": "path",
          "field": "path"
        },
        {
          "kind": "listItemNames",
          "field": "fields",
          "style": "camel",
          "reason": "field names use camelCase"
        }
      ],
      "validatorRules": [
        {
          "kind": "nameCase",
          "field": "name",
          "style": "pascal",
          "message": "Class name must use PascalCase"
        },
        {
          "kind": "pathSegmentCase",
          "field": "path",
          "style": "lower",
          "code": "INVALID_PACKAGE_SEGMENT",
          "message": "Backend package segments must use lower-case"
        },
        {
          "kind": "springBasePackage",
          "field": "basePackage"
        }
      ],
      "render": {
        "templateFile": "templates/entity.java",
        "output": {
          "filePattern": "src/main/java/{basePackagePath}/{path}/entity/{name}.java"
        },
        "contextTokens": ["className", "basePackage", "packagePathDot", "basePackagePath", "entityFields"]
      },
      "examples": [
        "tcb entity --json '{\"name\":\"Product\",\"path\":\"product\",\"basePackage\":\"com.example.app\"}'"
      ]
    },
    "batch": {
      "description": "Execute multiple backend file ops in one request",
      "inputMode": "json",
      "execution": {
        "kind": "batch"
      },
      "examples": [
        "tcb batch --json '{\"ops\":[{\"id\":\"request-dto\",\"command\":\"requestDto\",\"spec\":{\"name\":\"CreateProductRequest\",\"path\":\"product\",\"basePackage\":\"com.example.app\"}}]}'"
      ]
    }
  }
}

            "id": "requestDto",
            "reason": "Define the request DTO together"
          },
          {
            "id": "entity",
            "reason": "Generate the entity shell referenced by the response"
          },
          {
            "id": "batch",
            "reason": "Run multiple file generation tasks in one request"
          }
        ],
        "flowRefs": [
          "create-spring-feature",
          "bulk-backend-scaffold"
        ]
      },
      "guide": {

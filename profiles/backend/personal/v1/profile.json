    },
    "batch": {
      "description": "Execute multiple backend file ops in one request",
      "summary": {
        "whenToUse": [
          "When you want to preview or apply multiple backend file generation tasks in one request"
        ],
        "relatedCommands": [
          {
            "id": "module",
            "reason": "Bundle feature skeleton generation"
          },
          {
            "id": "requestDto",
            "reason": "Bundle request DTO generation"
          },
          {
            "id": "responseDto",
            "reason": "Bundle response DTO generation"
          },
          {
            "id": "entity",
            "reason": "Bundle entity generation"
          }
        ],
        "flowRefs": [
          "bulk-backend-scaffold",
          "create-spring-feature"
        ]
      },
      "guide": {
        "목적": "여러 백엔드 파일 생성 작업을 한 번의 요청으로 순차 실행한다.",
        "입력규칙": [
          "ops 배열은 순서대로 실행된다.",
          "앞선 op 결과는 $ref로 뒤 op에서 참조할 수 있다."
        ],
        "출력규칙": [
          "기본은 preview다.",
          "--apply일 때만 마지막에 한 번 write 한다.",
          "하나라도 실패하면 전체 write를 취소한다."
        ]
      },
      "inputMode": "json",
      "execution": {
        "kind": "batch"
      },
      "examples": [
        "backend batch --json '{\"ops\":[{\"id\":\"request-dto\",\"command\":\"requestDto\",\"spec\":{\"name\":\"CreateProductRequest\",\"path\":\"product\",\"basePackage\":\"com.example.app\"}}]}'"
      ]

{
  "id": "publisher/personal/v1",
  "kind": "publisher-profile",
  "alias": "tcp",
  "extends": ["shared/personal/v1"],
  "rules": {
    "guidance": {
      "placementRules": [
        "Use components/common when reused in 2 or more domains or pages.",
        "Use components/{domain} for domain-specific components.",
        "Nested UI parts may live under the parent component folder."
      ]
    }
  },
  "commands": {
    "component": {
      "description": "Generate a publisher UI component file",
      "inputMode": "json",
      "execution": {
        "kind": "file"
      },
      "generator": {
        "kind": "singleFile"
      },
      "output": {
        "filePattern": "{path}/index.tsx"
      },
      "templateFile": "templates/component.default.tsx",
      "rules": {
        "enforced": {
          "pathPolicy": {
            "allowedRoots": ["components", "page", "app"]
          },
          "componentStyle": {
            "functionStyle": "arrow",
            "exportStyle": "default",
            "propsDestructure": "insideBody"
          },
          "logicBoundary": {
            "allowUiState": true,
            "allowedUiStateExamples": ["toggle", "sidebar", "accordion", "modal", "tab"],
            "forbiddenPatterns": ["useEffect(", "fetch(", "axios.", "useQuery(", "useMutation("]
          }
        }
      },
      "examples": [
        "tcp component --json '{\"name\":\"HomePage\",\"path\":\"page/homePage\"}'"
      ]
    },
    "uiState": {
      "description": "Render UI interaction state and handlers snippet",
      "inputMode": "json",
      "execution": {
        "kind": "snippet",
        "language": "ts"
      },
      "examples": [
        "tcp uiState --json '{\"category\":\"uiInteraction\",\"pattern\":\"toggle\",\"name\":\"menu\"}'"
      ]
    },
    "batch": {
      "description": "Execute multiple publisher ops in one request",
      "inputMode": "json",
      "execution": {
        "kind": "batch"
      },
      "examples": [
        "tcp batch --json '{\"ops\":[{\"id\":\"component\",\"command\":\"component\",\"spec\":{\"name\":\"HomePage\",\"path\":\"page/homePage\"}}]}'"
      ]
    }
  }
}

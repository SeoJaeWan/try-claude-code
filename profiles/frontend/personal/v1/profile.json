        "arrays": [
          "params"
        ]
      },
      "defaults": {
        "scope": "detail",
        "params": []
      },
      "namingPolicy": {
        "suffixes": {
          "queryKeyFunction": "QueryKey"
        }
      },
      "normalizationRules": [
        {
          "kind": "case",

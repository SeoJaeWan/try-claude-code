        {
          "kind": "case",
          "field": "scope",
          "style": "camel",
          "reason": "query key scope uses camelCase"
        },
        {
          "kind": "stringList",
          "field": "params",
          "style": "camel",
          "reason": "query key params use camelCase"
        }
      ],
      "render": {

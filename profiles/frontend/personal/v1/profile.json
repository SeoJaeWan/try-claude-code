{
  "id": "frontend/personal/v1",
  "kind": "frontend-profile",
  "alias": "tcf",
  "extends": ["shared/personal/v1"],
  "guide": {
    "요약": "프론트엔드 personal v1 규칙이다. 훅, API 훅, 프론트엔드용 snippet을 다룬다.",
    "공통규칙": [
      "훅은 use prefix를 사용한다.",
      "API 요청 로직은 apiHook으로 만들고 TanStack Query 기준을 따른다.",
      "비 API 훅은 hooks/utils/{domain} 또는 hooks/utils/common 경로에 둔다.",
      "API 훅은 hooks/apis/{domain}/queries 또는 hooks/apis/{domain}/mutations 경로에 둔다.",
      "domain은 owner feature root를 사용하고, 여러 도메인에서 공통이면 common을 사용한다."
    ]
  },
  "commands": {
    "hook": {
      "description": "Generate a non-API hook file",
      "contracts": {
        "hookKind": "custom",
        "pathPolicy": {
          "allowedPatterns": ["hooks/utils/{domain}", "hooks/utils/common"],
          "forbiddenExamples": ["hooks/login", "app/login/hooks", "components/toggle/hooks"],
          "domainPolicy": "domain is the owner feature root; use common only for cross-domain shared hooks"
        },
        "namingPolicy": {
          "requiredPrefix": "use",
          "requiredPattern": "^use[A-Z][A-Za-z0-9]*$"
        }
      },
      "guide": {
        "목적": "일반 훅 파일 껍질을 생성한다.",
        "입력규칙": [
          "name과 path는 필수다."
        ],
        "이름규칙": [
          "훅 이름은 use* 규칙을 사용한다."
        ],
        "출력규칙": [
          "출력 파일은 {path}/{name}/index.ts 이다.",
          "경로는 hooks/utils/{domain} 또는 hooks/utils/common 만 허용한다.",
          "화살표 함수와 export default를 사용한다."
        ]
      },
      "inputMode": "json",
      "execution": {
        "kind": "file"
      },
      "inputSchema": {
        "required": ["name", "path"]
      },
      "namingPolicy": {
        "prefixes": {
          "hook": "use"
        }
      },
      "generator": {
        "kind": "singleFile"
      },
      "normalizationRules": [
        {
          "kind": "prefixedName",
          "field": "name",
          "prefixKey": "hook",
          "style": "pascal",
          "reason": "hooks use use*"
        },
        {
          "kind": "path",
          "field": "path"
        }
      ],
      "validatorRules": [
        {
          "kind": "pathRoots",
          "field": "path",
          "allowedRoots": ["hooks"]
        },
        {
          "kind": "pathSegmentCase",
          "field": "path",
          "style": "camel",
          "message": "Path segments must use camelCase"
        },
        {
          "kind": "namePrefix",
          "field": "name",
          "prefixKey": "hook",
          "message": "Hook name must start with use"
        },
        {
          "kind": "hookPathPolicy",
          "field": "path",
          "baseSegments": ["hooks", "utils"],
          "sharedSegment": "common"
        }
      ],
      "render": {
        "templateFile": "templates/hook.default.ts",
        "output": {
          "filePattern": "{path}/{name}/index.ts"
        },
        "contextTokens": ["hookName"]
      },
      "examples": [
        "tcf hook --json '{\"name\":\"useScroll\",\"path\":\"hooks/utils/common\"}'"
      ]
    },
    "apiHook": {
      "description": "Generate a TanStack Query API hook file",
      "contracts": {
        "hookKind": "api",
        "pathPolicy": {
          "requiredPattern": "hooks/apis/{domain}/{queries|mutations}",
          "domainPolicy": "domain is the owner feature root",
          "kindSegments": {
            "query": "queries",
            "mutation": "mutations"
          }
        },
        "methodPolicy": {
          "query": {
            "requiredMethod": "GET"
          },
          "mutation": {
            "allowedMethods": ["POST", "PUT", "PATCH", "DELETE"]
          }
        },
        "namingPolicy": {
          "queryPattern": "^useGet[A-Z][A-Za-z0-9]*$",
          "mutationPatterns": {
            "POST": "^usePost[A-Z][A-Za-z0-9]*$",
            "PUT": "^usePut[A-Z][A-Za-z0-9]*$",
            "PATCH": "^usePatch[A-Z][A-Za-z0-9]*$",
            "DELETE": "^useDelete[A-Z][A-Za-z0-9]*$"
          },
          "forbiddenPrefixes": ["useFetch", "useSave", "useSubmit"]
        }
      },
      "guide": {
        "목적": "TanStack Query 기반 API 훅 파일을 생성한다.",
        "입력규칙": [
          "name, path, kind는 필수다.",
          "kind는 query 또는 mutation만 허용한다.",
          "method는 query면 GET, mutation이면 POST/PUT/PATCH/DELETE를 사용한다."
        ],
        "이름규칙": [
          "query 훅 이름은 useGet* 규칙을 사용한다.",
          "mutation 훅 이름은 usePost*, usePut*, usePatch*, useDelete* 규칙을 사용한다."
        ],
        "출력규칙": [
          "출력 파일은 {path}/{name}/index.ts 이다.",
          "경로는 hooks/apis/{domain}/queries 또는 hooks/apis/{domain}/mutations 만 허용한다.",
          "query는 queries, mutation은 mutations 경로를 사용해야 한다."
        ],
        "주의사항": [
          "API 훅은 서버 요청 로직에만 사용한다."
        ]
      },
      "inputMode": "json",
      "execution": {
        "kind": "file"
      },
      "inputSchema": {
        "required": ["name", "path", "kind"],
        "enums": {
          "kind": ["query", "mutation"]
        }
      },
      "defaults": {
        "method": "GET"
      },
      "namingPolicy": {
        "prefixes": {
          "hook": "use"
        }
      },
      "generator": {
        "kind": "singleFile"
      },
      "normalizationRules": [
        {
          "kind": "prefixedName",
          "field": "name",
          "prefixKey": "hook",
          "style": "pascal",
          "reason": "hooks use use*"
        },
        {
          "kind": "uppercase",
          "field": "method",
          "reason": "HTTP method uses uppercase"
        },
        {
          "kind": "path",
          "field": "path"
        }
      ],
      "validatorRules": [
        {
          "kind": "pathRoots",
          "field": "path",
          "allowedRoots": ["hooks"]
        },
        {
          "kind": "pathSegmentCase",
          "field": "path",
          "style": "camel",
          "message": "Path segments must use camelCase"
        },
        {
          "kind": "namePrefix",
          "field": "name",
          "prefixKey": "hook",
          "message": "Hook name must start with use"
        },
        {
          "kind": "apiHookMethodPolicy",
          "kindField": "kind",
          "methodField": "method",
          "queryMethod": "GET",
          "mutationMethods": ["POST", "PUT", "PATCH", "DELETE"]
        },
        {
          "kind": "apiHookPath",
          "field": "path",
          "kindField": "kind",
          "apiRoot": "hooks/apis",
          "requiredSegment": "/apis/",
          "suffixMap": {
            "query": "queries",
            "mutation": "mutations"
          }
        },
        {
          "kind": "apiHookNamePolicy",
          "field": "name",
          "kindField": "kind",
          "methodField": "method",
          "queryPrefix": "useGet",
          "mutationPrefixMap": {
            "POST": "usePost",
            "PUT": "usePut",
            "PATCH": "usePatch",
            "DELETE": "useDelete"
          },
          "forbiddenPrefixes": ["useFetch", "useSave", "useSubmit"]
        }
      ],
      "render": {
        "templateFiles": {
          "query": "templates/api-hook.query.ts",
          "mutation": "templates/api-hook.mutation.ts"
        },
        "templateVariantField": "kind",
        "output": {
          "filePattern": "{path}/{name}/index.ts"
        },
        "contextTokens": ["hookName", "domainName"]
      },
      "examples": [
        "tcf apiHook --json '{\"name\":\"useGetProduct\",\"path\":\"hooks/apis/product/queries\",\"kind\":\"query\",\"method\":\"GET\"}'"
      ]
    },
    "queryKey": {
      "description": "Render a TanStack Query key snippet",
      "guide": {
        "목적": "TanStack Query key 함수 껍질을 만든다.",
        "입력규칙": [
          "domain은 필수다.",
          "scope와 params는 선택값이지만 규칙에 맞게 정규화된다."
        ],
        "이름규칙": [
          "domain과 scope는 camelCase를 사용한다.",
          "함수명 suffix는 현재 profile recipe를 따른다."
        ],
        "출력규칙": [
          "query key 함수와 배열 멤버 구성을 함께 반환한다."
        ]
      },
      "inputMode": "json",
      "execution": {
        "kind": "snippet",
        "language": "ts"
      },
      "inputSchema": {
        "required": ["domain"],
        "arrays": ["params"]
      },
      "defaults": {
        "scope": "detail",
        "params": []
      },
      "namingPolicy": {
        "suffixes": {
          "queryKeyFunction": "QueryKey"
        }
      },
      "normalizationRules": [
        {
          "kind": "case",
          "field": "domain",
          "style": "camel",
          "reason": "query key domain uses camelCase"
        },
        {
          "kind": "case",
          "field": "scope",
          "style": "camel",
          "reason": "query key scope uses camelCase"
        },
        {
          "kind": "stringList",
          "field": "params",
          "style": "camel",
          "reason": "query key params use camelCase"
        }
      ],
      "render": {
        "snippetTemplate": "templates/query-key.ts",
        "contextTokens": ["queryKeyFunctionName", "queryKeyParamsSignature", "queryKeyMembers"]
      },
      "examples": [
        "tcf queryKey --json '{\"domain\":\"product\",\"scope\":\"detail\",\"params\":[\"productId\"]}'"
      ]
    },
    "endpoint": {
      "description": "Render an API endpoint constant snippet",
      "guide": {
        "목적": "API endpoint 상수 껍질을 만든다.",
        "입력규칙": [
          "method, resource, path는 필수다."
        ],
        "이름규칙": [
          "method는 대문자로 정규화한다.",
          "resource는 camelCase를 사용한다.",
          "상수명은 현재 profile의 prefix, suffix 규칙으로 생성한다."
        ],
        "출력규칙": [
          "상수명과 endpoint path를 함께 반환한다."
        ]
      },
      "inputMode": "json",
      "execution": {
        "kind": "snippet",
        "language": "ts"
      },
      "inputSchema": {
        "required": ["method", "resource", "path"]
      },
      "normalizationRules": [
        {
          "kind": "uppercase",
          "field": "method",
          "reason": "HTTP method uses uppercase"
        },
        {
          "kind": "case",
          "field": "resource",
          "style": "camel",
          "reason": "endpoint resource uses camelCase"
        },
        {
          "kind": "derive",
          "field": "constantName",
          "kindName": "httpConstant"
        }
      ],
      "render": {
        "snippetTemplate": "templates/endpoint.ts",
        "contextTokens": ["endpointConstantName", "path"]
      },
      "examples": [
        "tcf endpoint --json '{\"method\":\"GET\",\"resource\":\"product\",\"path\":\"/products/:productId\"}'"
      ]
    },
    "mapper": {
      "description": "Render a mapper function snippet",
      "guide": {
        "목적": "응답 타입을 뷰 모델로 바꾸는 mapper 함수 껍질을 만든다.",
        "입력규칙": [
          "sourceType과 targetType은 필수다."
        ],
        "이름규칙": [
          "mapper 이름은 profile의 prefix와 joiner 규칙으로 생성한다.",
          "최종 함수명은 camelCase를 사용한다."
        ],
        "출력규칙": [
          "mapper 함수 시그니처와 기본 본문을 반환한다."
        ]
      },
      "inputMode": "json",
      "execution": {
        "kind": "snippet",
        "language": "ts"
      },
      "inputSchema": {
        "required": ["sourceType", "targetType"]
      },
      "namingPolicy": {
        "prefixes": {
          "mapper": "map"
        },
        "joiners": {
          "mapper": "To"
        }
      },
      "normalizationRules": [
        {
          "kind": "derive",
          "field": "name",
          "kindName": "mapperName",
          "reason": "mapper names use camelCase"
        }
      ],
      "render": {
        "snippetTemplate": "templates/mapper.ts",
        "contextTokens": ["mapperName", "sourceType", "targetType"]
      },
      "examples": [
        "tcf mapper --json '{\"sourceType\":\"ProductResponse\",\"targetType\":\"ProductViewModel\"}'"
      ]
    },
    "hookReturn": {
      "description": "Render a hook return snippet",
      "guide": {
        "목적": "훅이 반환할 값과 액션 구조를 만든다.",
        "입력규칙": [
          "values와 actions 배열을 전달할 수 있다."
        ],
        "이름규칙": [
          "반환 값과 액션 이름은 camelCase를 사용한다."
        ],
        "출력규칙": [
          "return object에 들어갈 멤버 목록을 반환한다."
        ]
      },
      "inputMode": "json",
      "execution": {
        "kind": "snippet",
        "language": "ts"
      },
      "inputSchema": {
        "arrays": ["values", "actions"]
      },
      "defaults": {
        "values": [],
        "actions": []
      },
      "normalizationRules": [
        {
          "kind": "listItemNames",
          "field": "values",
          "style": "camel",
          "reason": "hook return values use camelCase"
        },
        {
          "kind": "listItemNames",
          "field": "actions",
          "style": "camel",
          "reason": "hook return actions use camelCase"
        }
      ],
      "render": {
        "snippetTemplate": "templates/hook-return.ts",
        "contextTokens": ["hookReturnMembers"]
      },
      "examples": [
        "tcf hookReturn --json '{\"values\":[{\"name\":\"product\",\"type\":\"ProductViewModel | null\"}],\"actions\":[{\"name\":\"refetch\",\"type\":\"() => Promise<void>\"}]}'"
      ]
    },
    "batch": {
      "description": "Execute multiple frontend ops in one request",
      "guide": {
        "목적": "여러 프론트엔드 작업을 한 번의 요청으로 순차 실행한다.",
        "입력규칙": [
          "ops 배열은 순서대로 실행된다.",
          "앞선 op 결과는 $ref로 뒤 op에서 참조할 수 있다."
        ],
        "출력규칙": [
          "기본은 preview다.",
          "--apply일 때만 마지막에 한 번 write 한다.",
          "하나라도 실패하면 전체 write를 취소한다."
        ]
      },
      "inputMode": "json",
      "execution": {
        "kind": "batch"
      },
      "examples": [
        "tcf batch --json '{\"ops\":[{\"id\":\"hook\",\"command\":\"hook\",\"spec\":{\"name\":\"useScroll\",\"path\":\"hooks/utils/common\"}}]}'"
      ]
    }
  }
}

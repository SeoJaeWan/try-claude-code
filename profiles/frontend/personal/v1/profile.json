{
  "id": "frontend/personal/v1",
  "kind": "frontend-profile",
  "alias": "tcf",
  "extends": ["shared/personal/v1"],
  "commands": {
    "hook": {
      "description": "Generate a non-API hook file",
      "inputMode": "json",
      "execution": {
        "kind": "file"
      },
      "generator": {
        "kind": "singleFile"
      },
      "output": {
        "filePattern": "{path}/{name}/index.ts"
      },
      "templateFile": "templates/hook.default.ts",
      "rules": {
        "enforced": {
          "pathPolicy": {
            "allowedRoots": ["hooks", "src", "app", "components"]
          },
          "hookStyle": {
            "functionStyle": "arrow",
            "exportStyle": "default"
          }
        }
      },
      "examples": [
        "tcf hook --json '{\"name\":\"useScroll\",\"path\":\"hooks/utils\"}'"
      ]
    },
    "apiHook": {
      "description": "Generate a TanStack Query API hook file",
      "inputMode": "json",
      "execution": {
        "kind": "file"
      },
      "generator": {
        "kind": "singleFile"
      },
      "output": {
        "filePattern": "{path}/{name}/index.ts"
      },
      "templateFiles": {
        "query": "templates/api-hook.query.ts",
        "mutation": "templates/api-hook.mutation.ts"
      },
      "rules": {
        "enforced": {
          "pathPolicy": {
            "allowedRoots": ["hooks", "src", "app"]
          },
          "library": {
            "queryClient": "@tanstack/react-query"
          }
        }
      },
      "examples": [
        "tcf apiHook --json '{\"name\":\"useGetProduct\",\"path\":\"hooks/apis/product/queries\",\"kind\":\"query\"}'"
      ]
    },
    "queryKey": {
      "description": "Render a TanStack Query key snippet",
      "inputMode": "json",
      "execution": {
        "kind": "snippet",
        "language": "ts"
      },
      "examples": [
        "tcf queryKey --json '{\"domain\":\"product\",\"scope\":\"detail\",\"params\":[\"productId\"]}'"
      ]
    },
    "endpoint": {
      "description": "Render an API endpoint constant snippet",
      "inputMode": "json",
      "execution": {
        "kind": "snippet",
        "language": "ts"
      },
      "examples": [
        "tcf endpoint --json '{\"method\":\"GET\",\"resource\":\"product\",\"path\":\"/products/:productId\"}'"
      ]
    },
    "mapper": {
      "description": "Render a mapper function snippet",
      "inputMode": "json",
      "execution": {
        "kind": "snippet",
        "language": "ts"
      },
      "examples": [
        "tcf mapper --json '{\"sourceType\":\"ProductResponse\",\"targetType\":\"ProductViewModel\"}'"
      ]
    },
    "hookReturn": {
      "description": "Render a hook return snippet",
      "inputMode": "json",
      "execution": {
        "kind": "snippet",
        "language": "ts"
      },
      "examples": [
        "tcf hookReturn --json '{\"values\":[{\"name\":\"product\",\"type\":\"ProductViewModel | null\"}],\"actions\":[{\"name\":\"refetch\",\"type\":\"() => Promise<void>\"}]}'"
      ]
    },
    "batch": {
      "description": "Execute multiple frontend ops in one request",
      "inputMode": "json",
      "execution": {
        "kind": "batch"
      },
      "examples": [
        "tcf batch --json '{\"ops\":[{\"id\":\"hook\",\"command\":\"hook\",\"spec\":{\"name\":\"useScroll\",\"path\":\"hooks/utils\"}}]}'"
      ]
    }
  }
}
